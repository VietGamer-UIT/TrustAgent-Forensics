# =============================================================================
# TrustAgent.Forensics — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# --- PostgreSQL Database ---
DATABASE_URL=postgresql+asyncpg://trustagent:trustagent_secret@localhost:5432/trustagent_db

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-random-secret-key

# --- Z3 Engine ---
Z3_TIMEOUT_MS=5000
Z3_MAX_RETRIES=3

# --- LangGraph ---
LANGGRAPH_MAX_ITERATIONS=10
LANGGRAPH_HUMAN_APPROVAL_THRESHOLD=50000000
